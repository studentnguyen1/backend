    updatedBy: String
}
' done
class User {
    id : long
    name : String
    email : String
    password : String
    age : int
    gender : Enums
    address : String
    refreshToken : String
    createdAt : Instant
    updatedAt : Instant
    createdBy: String
    updatedBy: String
}
' donee
class Role {
    id : long
    name : String
    description : String
    isActive : boolean
    createdAt : Instant
    updatedAt : Instant
    createdBy: String
    updatedBy: String
    }

' Relationships
User "n" -- "1" Role 
User "n" -- "1" Company 
User "1" -- "1" Subscriber
User "1" -- "*" Resume
Company "1" -- "*" Resume 
Company "1" -- "*" Job 
Job "*" -- "*" Skill 
Role "*" -- "*" Permission
Subscriber "*" -- "*" Skill 

@enduml