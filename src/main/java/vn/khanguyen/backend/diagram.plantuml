@startuml
' doneee
class Company {
    id : long
    name : String
    description : String
    address : String
    logo : String
    createdAt : Instant
    updatedAt : Instant
    createdBy: String
    updatedBy: String
}
' doneee
class Job {
    id : long
    name : String
    location : String
    salary : double
    quantity : int
    level : Enums
    description : String
    startDate : Instant
    endDate : Instant
    isActive : boolean
    createdAt : Instant
    updatedAt : Instant
    createdBy: String
    updatedBy: String
}
' doneee
class Permission {
    id : long
    name : String
    apiPath : String
    method : String
    module : String
    createdAt : Instant
    updatedAt : Instant
    createdBy : String
    updatedBy : String
}
' doneee
class Resume {
    id : long
    email : String
    url : String
    status : Enums
    createdAt : Date
    updatedAt : Date
    createdBy : String
    updatedBy : String
}
' doneee
class Skill {
    id : long
